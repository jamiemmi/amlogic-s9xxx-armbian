From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: custom-build <build@panther-x2.local>
Date: Sat, 28 Mar 2026 00:00:00 +0800
Subject: [PATCH 1/3] dts/rockchip: add Panther-X2 custom device tree

将自定义 Panther-X2 DTS 注册进 Kbuild，
使编译时自动产出 rk3566-panther-x2-custom.dtb。
---
 arch/arm64/boot/dts/rockchip/Makefile | 1 +
 1 file changed, 1 insertion(+)

diff --git a/arch/arm64/boot/dts/rockchip/Makefile b/arch/arm64/boot/dts/rockchip/Makefile
index xxxxxxx..yyyyyyy 100644
--- a/arch/arm64/boot/dts/rockchip/Makefile
+++ b/arch/arm64/boot/dts/rockchip/Makefile
@@ -80,6 +80,7 @@ dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3566-orangepi-3b.dtb
 dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3566-panther-x2.dtb
+dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3566-panther-x2-custom.dtb
 dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3566-pinenote-v1.1.dtb
 dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3566-quartz64-a.dtb
--
